/*-----------------------------------------------------------
 * MDIO0 Bus: RGMII PHY Node
 * compatible: Standard Ethernet PHY type
 * reg: PHY address
 * clocks: 25MHz reference clock, usually for PHY crystal and link synchronization
 *----------------------------------------------------------*/
&mdio0 {
	rgmii_phy0: phy@1 {
		compatible = "ethernet-phy-ieee802.3-c22";  // Standard C22 Ethernet PHY
		reg = <0x1>;                                // PHY address 1
		clocks = <&cru REFCLKO25M_GMAC0_OUT>;       // 25MHz reference clock
	};
};

/*-----------------------------------------------------------
 * MDIO1 Bus: RGMII PHY1 Node
 *----------------------------------------------------------*/
&mdio1 {
	rgmii_phy1: phy@1 {
		compatible = "ethernet-phy-ieee802.3-c22";
		reg = <0x1>;
		clocks = <&cru REFCLKO25M_GMAC1_OUT>;
	};
};

/*-----------------------------------------------------------
 * GMAC0 Main Controller Node
 * phy-mode: RGMII-RXID mode, disable SoC internal RX delay, handled by PHY
 * clock_in_out: 25MHz clock output to PHY
 * snps,reset-gpio: PHY reset pin, active low reset
 * snps,reset-active-low: Reset signal active low
 * snps,reset-delays-us: Reset timing (0us pull low, 20ms hold, 100ms release)
 * pinctrl-names/pinctrl-0: Bind Ethernet related pins
 * tx_delay: Transmit timing delay (0x22, adapted per board)
 * rx_delay: Receive delay (commented here, default handled by PHY)
 * phy-handle: Bind to rgmii_phy0 under MDIO0
 * status: Enable GMAC0
 *----------------------------------------------------------*/
&gmac0 {
	phy-mode = "rgmii-rxid";    // RGMII mode, RX delay handled by PHY
	clock_in_out = "output";

	snps,reset-gpio = <&gpio2 RK_PB3 GPIO_ACTIVE_LOW>;  // PHY reset GPIO, active low
	snps,reset-active-low;                              // Reset active low
	snps,reset-delays-us = <0 20000 100000>;            // Reset timing, 0us pull low→20ms hold→100ms release

	pinctrl-names = "default";
	pinctrl-0 = <&eth0m0_miim
			&eth0m0_tx_bus2
			&eth0m0_rx_bus2
			&eth0m0_rgmii_clk
			&eth0m0_rgmii_bus
			&eth0m0_mclk>;

	tx_delay = <0x24>;  // TX timing delay (requires board-level calibration)

    /* disable internal rx delay */
	/* rx_delay = <>; */

	phy-handle = <&rgmii_phy0>;     // Specify physical PHY binding
	status = "okay";                // Enable GMAC0
};


/*-----------------------------------------------------------
 * GMAC1 Controller Node
 * Default status = "disabled", disabled because second Ethernet port is not exposed
 *----------------------------------------------------------*/
&gmac1 {
	status = "disabled";
};
