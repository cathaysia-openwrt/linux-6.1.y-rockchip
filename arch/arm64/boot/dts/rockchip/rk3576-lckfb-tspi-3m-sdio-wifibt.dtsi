/ {
	/*
	 * Bluetooth Platform Data Node
	 * compatible: Bluetooth driver platform type
	 * uart_rts_gpios: Bluetooth UART RTS pin
	 * pinctrl-names: Default and RTS dedicated pinmux configuration
	 * pinctrl-0: UART6 RTS signal pin
	 * pinctrl-1: UART6 GPIO pin
	 * BT,reset_gpio: Bluetooth module reset pin
	 * BT,wake_gpio: Bluetooth wake pin
	 * BT,wake_host_irq: Bluetooth wake host interrupt pin
	 */
	wireless_bluetooth: wireless-bluetooth {
		status = "okay";                                      // Enable Bluetooth
		compatible = "bluetooth-platdata";
		clocks = <&hym8563>;                            	  // RTC output 32KHz clock
		clock-names = "ext_clock";
		uart_rts_gpios = <&gpio2 RK_PD4 GPIO_ACTIVE_LOW>;     // UART RTS pin
		pinctrl-names = "default", "rts_gpio";                // Default/RTS pin configuration
		pinctrl-0 = <&uart6m1_rtsn>;                          // UART6 RTS
		pinctrl-1 = <&uart6_gpios>;                           // UART6 GPIO
		BT,reset_gpio    = <&gpio1 RK_PC7 GPIO_ACTIVE_HIGH>;  // Bluetooth reset
		BT,wake_gpio     = <&gpio1 RK_PD4 GPIO_ACTIVE_HIGH>;  // Bluetooth wake
		BT,wake_host_irq = <&gpio0 RK_PB1 GPIO_ACTIVE_HIGH>;  // Wake host interrupt
	};

	/*
	 * WiFi Platform Data Node
	 * compatible: WiFi driver platform type
	 * clocks: External clock source (RTC 32KHz here, must ensure RTC is started)
	 * wifi_chip_type: WiFi chip model
	 * pinctrl-names: Default pinmux configuration
	 * pinctrl-0: WiFi wake host IRQ pin
	 * WIFI,vbat_gpio: WiFi VBAT power control pin
	 * WIFI,host_wake_irq: WiFi wake host interrupt pin
	 * WIFI,poweren_gpio: WiFi power enable pin (comment out if using sdio_pwrseq)
	 */
	wireless_wlan: wireless-wlan {
		status = "okay";                                // Enable WiFi
		compatible = "wlan-platdata";
		clocks = <&hym8563>;                            // RTC output 32KHz clock
		clock-names = "ext_clock";
		wifi_chip_type = "";                      		// WiFi chip type (currently not identified by this property)
		pinctrl-names = "default";
		pinctrl-0 = <&wifi_host_wake_irq>;              // Wake host IRQ pin
		WIFI,vbat_gpio = <&gpio0 RK_PD1 GPIO_ACTIVE_HIGH>; // VBAT power enable
		WIFI,host_wake_irq = <&gpio0 RK_PB0 GPIO_ACTIVE_HIGH>; // Wake host
		WIFI,poweren_gpio = <&gpio1 RK_PC6 GPIO_ACTIVE_HIGH>; // WiFi power enable (needed for rfkill recovery)
	};

	/*
	 * SDIO Power Sequence Node
	 * compatible: Simple power sequence driver
	 * pinctrl-names/0: Power enable pin configuration
	 * post-power-on-delay-ms: Power-on delay (e.g. 200ms)
	 * reset-gpios: WiFi module reset pin (active low reset)
	 */
	sdio_pwrseq: sdio-pwrseq {
		status = "okay";                                 // Enable SDIO power sequence
		compatible = "mmc-pwrseq-simple";
		pinctrl-names = "default";
		pinctrl-0 = <&wifi_poweren_gpio>;
		post-power-on-delay-ms = <200>;                  // Power-on delay
		reset-gpios = <&gpio1 RK_PC6 GPIO_ACTIVE_LOW>;   // Reset pin
	};
};

/*-----------------------------------------------------------
 * Bluetooth UART Controller Node (UART6)
 * pinctrl-names/0: UART6 signal + CTS pin configuration
 * status: Enable UART6
 *----------------------------------------------------------*/
&uart6 {
	pinctrl-names = "default";
	pinctrl-0 = <&uart6m1_xfer &uart6m1_ctsn>;
	status = "okay";
};

/*-----------------------------------------------------------
 * WiFi/BT SDIO Controller Node
 * Main property descriptions:
 * max-frequency: Supports maximum frequency 200MHz
 * no-sd/no-mmc: Disable normal SD/MMC card function, SDIO only
 * bus-width: Data bus 4-bit
 * disable-wp: Disable write protection
 * cap-sd-highspeed: Supports high-speed SD
 * cap-sdio-irq: Supports SDIO interrupt
 * keep-power-in-suspend: Keep power during suspend
 * mmc-pwrseq: Bind SDIO power sequence node
 * non-removable: Onboard module non-removable
 * pinctrl-names/0: SDIO signal pin configuration
 * sd-uhs-sdr104: Supports SDR104 (up to 104MB/s)
 *----------------------------------------------------------*/
&sdio {
	status = "okay";
	max-frequency = <200000000>;
	no-sd;
	no-mmc;
	bus-width = <4>;
	disable-wp;
	cap-sd-highspeed;
	cap-sdio-irq;
	keep-power-in-suspend;
	mmc-pwrseq = <&sdio_pwrseq>;
	non-removable;
	pinctrl-names = "default";
	pinctrl-0 = <&sdmmc1m0_bus4 &sdmmc1m0_clk &sdmmc1m0_cmd>;
	sd-uhs-sdr104;
};

/*-----------------------------------------------------------
 * Pin Multiplexing Configuration (Pinmux)
 * Pinmux Node for Wireless (WiFi/BT)
 * wireless-bluetooth: Bluetooth UART6 RTS GPIO
 * wireless-wlan: WiFi wake host IRQ & WiFi power enable GPIO
 *----------------------------------------------------------*/
&pinctrl {
	wireless-bluetooth {
		uart6_gpios: uart6-gpios {
			rockchip,pins = <2 RK_PD4 RK_FUNC_GPIO &pcfg_pull_none>;   // UART6 RTS GPIO
		};
	};

	wireless-wlan {
		wifi_host_wake_irq: wifi-host-wake-irq {
			rockchip,pins = <0 RK_PB0 RK_FUNC_GPIO &pcfg_pull_down>;   // WiFi wake host IRQ
		};

		wifi_poweren_gpio: wifi-poweren-gpio {
			rockchip,pins = <1 RK_PC6 RK_FUNC_GPIO &pcfg_pull_up>;     // WiFi power enable GPIO
		};
	};
};

