/*-----------------------------------------------------------
 * Camera Power Enable
 *----------------------------------------------------------*/
&vcc_1v2_mipi_csi {
	status = "okay";
};

&vcc_1v8_mipi_csi {
    status = "okay";
};

&vcc_2v8_mipi_csi {
    status = "okay";
};

/*-----------------------------------------------------------
 * Camera Link Configuration
 *----------------------------------------------------------*/
&i2c6 {
	status = "okay";
	pinctrl-0 = <&i2c6m1_xfer>;

	imx415_mipi3: imx415@1a {
        status = "okay";
		compatible = "sony,imx415";
		reg = <0x1a>;
		clocks = <&cru CLK_MIPI_CAMERAOUT_M2>;
        pinctrl-0 = <&cam_clk2m0_clk2>;
		clock-names = "xvclk";
		pinctrl-names = "default";
		power-domains = <&power RK3576_PD_VI>;

		avdd-supply = <&vcc_mipicsi3_avdd>;
		dovdd-supply = <&vcc_mipicsi3_dovdd>;
		dvdd-supply = <&vcc_mipicsi3_dvdd>;

		reset-gpios = <&gpio3 RK_PD5 GPIO_ACTIVE_LOW>;
		pwdn-gpios = <&gpio3 RK_PC7 GPIO_ACTIVE_HIGH>;

		rockchip,camera-module-index = <0>;
		rockchip,camera-module-facing = "back";
		rockchip,camera-module-name = "CMK-OT2022-PX1";
		rockchip,camera-module-lens-name = "IR0147-50IRC-8M-F20";

		port {
			imx415_dphy3_out0: endpoint {
				remote-endpoint = <&dphy3_in_imx415>;
				data-lanes = <1 2 3 4>;
			};
		};
	};

	imx415_mipi3_0: imx415-0@37 {
        status = "okay";
		compatible = "sony,imx415";
		reg = <0x37>;
		clocks = <&cru CLK_MIPI_CAMERAOUT_M2>;
        pinctrl-0 = <&cam_clk2m0_clk2>;
		clock-names = "xvclk";
		pinctrl-names = "default";
		power-domains = <&power RK3576_PD_VI>;

		avdd-supply = <&vcc_mipicsi3_avdd>;
		dovdd-supply = <&vcc_mipicsi3_dovdd>;
		dvdd-supply = <&vcc_mipicsi3_dvdd>;

		reset-gpios = <&gpio3 RK_PD5 GPIO_ACTIVE_LOW>;
		pwdn-gpios = <&gpio3 RK_PC7 GPIO_ACTIVE_HIGH>;

		rockchip,camera-module-index = <0>;
		rockchip,camera-module-facing = "back";
		rockchip,camera-module-name = "CMK-OT2022-PX1";
		rockchip,camera-module-lens-name = "IR0147-50IRC-8M-F20";

		port {
			imx415_0_dphy3_out0: endpoint {
				remote-endpoint = <&dphy3_in_imx415_0>;
				data-lanes = <1 2 3 4>;
			};
		};
	};

    /* Can continue to write other cameras by referring to imx415 configuration */
};



&csi2_dphy3 {
	status = "okay";

	ports {
		#address-cells = <1>;
		#size-cells = <0>;
		port@0 {
			reg = <0>;
			#address-cells = <1>;
			#size-cells = <0>;

			dphy3_in_imx415: endpoint@1 {
				reg = <1>;
				remote-endpoint = <&imx415_dphy3_out0>;
				data-lanes = <1 2 3 4>;
			};
            
            dphy3_in_imx415_0: endpoint@2 {
                reg = <2>;
                remote-endpoint = <&imx415_0_dphy3_out0>;
                data-lanes = <1 2 3 4>;
            };

            /* Can continue to write other cameras by referring to imx415 configuration */
			
		};
		port@1 {
			reg = <1>;
			#address-cells = <1>;
			#size-cells = <0>;

			csidphy3_out: endpoint@0 {
				reg = <0>;
				remote-endpoint = <&mipi3_csi2_input>;
			};
		};
	};
};


&mipi3_csi2 {
	status = "okay";

	ports {
		#address-cells = <1>;
		#size-cells = <0>;

		port@0 {
			reg = <0>;
			#address-cells = <1>;
			#size-cells = <0>;

			mipi3_csi2_input: endpoint@1 {
				reg = <1>;
				remote-endpoint = <&csidphy3_out>;
			};
		};

		port@1 {
			reg = <1>;
			#address-cells = <1>;
			#size-cells = <0>;

			mipi3_csi2_output: endpoint@0 {
				reg = <0>;
				remote-endpoint = <&cif_mipi3_in0>;
			};
		};
	};
};

&rkcif_mipi_lvds3 {
	status = "okay";

	port {
		cif_mipi3_in0: endpoint {
			remote-endpoint = <&mipi3_csi2_output>;
		};
	};
};

&rkcif_mipi_lvds3_sditf {
	status = "okay";

	port {
		mipi3_lvds_sditf: endpoint {
			remote-endpoint = <&isp_vir2>;
		};
	};
};

&rkisp_vir2 {
	status = "okay";

	port {
		#address-cells = <1>;
		#size-cells = <0>;

		isp_vir2: endpoint@0 {
			reg = <0>;
			remote-endpoint = <&mipi3_lvds_sditf>;
		};
	};
};


/*-----------------------------------------------------------
 * MIPI-CSI-3 Link Virtual Interface Enable
 *----------------------------------------------------------*/
&rkisp_vir2_sditf {
	status = "okay";
};

&rkvpss_vir2 {
	status = "okay";
};

/*-----------------------------------------------------------
 * General Configuration
 *----------------------------------------------------------*/
&rkcif {
	status = "okay";
};

&rkcif_mmu {
	status = "okay";
};

&rkisp {
	status = "okay";
};

&rkisp_mmu {
	status = "okay";
};

&rkvpss {
	status = "okay";
};

&rkvpss_mmu {
	status = "okay";
};
